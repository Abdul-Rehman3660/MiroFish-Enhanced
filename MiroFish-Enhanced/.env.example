# ============================================================
# MiroFish Enhanced — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
#
# Need help getting API keys?
# See: docs/free-llm-options.md
# ============================================================


# ============================================================
# REQUIRED: LLM API Configuration
# Supports any OpenAI-compatible API
# ============================================================

# --- Option 1: Alibaba Qwen-Plus (Recommended by MiroFish team - Cheapest)
# Sign up: https://bailian.console.aliyun.com/
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# --- Option 2: DeepSeek (Very cheap, high quality)
# Sign up: https://platform.deepseek.com/
# LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL_NAME=deepseek-chat

# --- Option 3: Groq (FREE tier available - very fast)
# Sign up: https://console.groq.com/
# LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL_NAME=llama-3.3-70b-versatile

# --- Option 4: Google Gemini Flash (FREE tier available)
# Sign up: https://aistudio.google.com/
# LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL_NAME=gemini-2.0-flash

# --- Option 5: OpenAI
# Sign up: https://platform.openai.com/
# LLM_API_KEY=your_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini


# ============================================================
# REQUIRED: Zep Cloud — Agent Memory
# Free tier is enough for basic usage
# Sign up: https://app.getzep.com/
# ============================================================
ZEP_API_KEY=your_zep_api_key_here


# ============================================================
# OPTIONAL: Speed Boost LLM (for faster simulations)
# Use a second, faster LLM for non-critical tasks
# Remove these lines if not using
# ============================================================
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here


# ============================================================
# OPTIONAL: Simulation Settings
# ============================================================

# Max rounds per simulation (lower = cheaper, faster)
# Recommended: start with 10, max 40 for testing
OASIS_DEFAULT_MAX_ROUNDS=10

# Report Agent settings
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
REPORT_AGENT_TEMPERATURE=0.5
